# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpass
DB_NAME=deployment_schedules

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# CLI Configuration
DEPLOYMENT_TAIL_API=http://localhost:8080

# Google OAuth Configuration
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URIs: http://localhost:8080/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# JWT Configuration
# SECURITY WARNING: Generate a strong random secret (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-must-be-at-least-32-characters-long
# Token expiry duration (e.g., 24h, 7d, 168h)
JWT_EXPIRY=24h
# JWT issuer (typically your application name)
JWT_ISSUER=deployment-tail
